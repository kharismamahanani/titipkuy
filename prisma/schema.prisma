// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Transaction-mode pooler (6543, pgbouncer) — dipakai runtime aplikasi.
  // Session-mode pooler (5432) cuma punya pool_size 15, gampang habis
  // kalau banyak koneksi serverless/dev bersamaan (ini penyebab menu
  // admin gagal load — bukan bug kode, tapi kehabisan slot koneksi DB).
  url       = env("DATABASE_URL")
  // Migrasi/db push butuh koneksi langsung (bukan transaction pooler).
  directUrl = env("DIRECT_URL")
}

model Pelanggan {
  id          String        @id @default(cuid())
  nama        String
  whatsapp    String
  alamatKos   String
  noKtpKtm    String?
  kampus      String?
  createdAt   DateTime      @default(now())
  transaksi   Transaksi[]
}

model Paket {
  id               String      @id @default(cuid())
  nama             String      // "Magang 3 Bulan", "Bulanan 5 Kardus", dll
  deskripsi        String?
  harga            Int         // dalam rupiah, selalu lunas
  durasiHari       Int?        // null = harian (dihitung per hari)
  kategori         String      // "harian" | "bulanan" | "magang" | "pindahan" | "motor"
  perluDeklarasi   Boolean     @default(false) // true = barang bernilai tinggi
  aktif            Boolean     @default(true)
  urutan           Int         @default(0)     // urutan tampil di landing page
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  transaksi        Transaksi[]
}

model Transaksi {
  id               String      @id @default(cuid())
  pelanggan        Pelanggan   @relation(fields:[pelangganId], references:[id])
  pelangganId      String
  paket            Paket       @relation(fields:[paketId], references:[id])
  paketId          String
  // Harga paket yang benar-benar tertagih — untuk kategori "harian" murni
  // (Paket.durasiHari null), ini = Paket.harga x jumlah hari kalender
  // (tanggalJatuhTempo - tanggalMasuk). Untuk paket berdurasi tetap
  // (bulanan/magang/motor/promo N-hari), sama dengan Paket.harga. Dihitung
  // & disimpan saat transaksi dibuat (lihat src/lib/harga-paket.ts) supaya
  // tetap akurat walau harga Paket berubah di kemudian hari.
  hargaPaketTertagih Int         @default(0)
  // Voucher diskon persen (opsional). hargaPaketTertagih di atas SUDAH
  // memperhitungkan diskon (nilai final tertagih); dua field di bawah
  // menyimpan snapshot harga asli & persen saat transaksi dibuat, supaya
  // riwayat tidak berubah walau Voucher itu sendiri diedit kemudian.
  voucher          Voucher?    @relation(fields:[voucherId], references:[id])
  voucherId        String?
  hargaSebelumDiskon   Int?
  persenDiskonTerpakai Int?
  // Jumlah barang fisik yang menentukan pengali harga saat order dibuat
  // (lihat src/lib/harga-paket.ts). TIDAK otomatis sinkron dengan hitungan
  // BarangLabel di src/app/api/admin/barang-label/route.ts — itu pencatatan
  // fisik per item yang diisi terpisah, konsep berbeda dari field ini.
  jumlahBarang         Int         @default(1)
  nilaiDeklarasi   Int?        // diisi jika perluDeklarasi = true
  deskripsiDeklarasi String?   // merek, model, no seri barang bernilai tinggi
  buktiKepemilikanUrl String?  // URL bukti kepemilikan (STNK/BPKB/nota) di Supabase Storage
  // Sistem ganti rugi berlapis (lihat src/lib/ganti-rugi.ts)
  tierGantiRugi    String?     // "standar" | "deklarasi" | "bernilaiTinggi"
  premiGantiRugi   Int?        // nominal rupiah premi perlindungan barang
  // Dokumen wajib khusus paket "Titip Motor" (verifikasi kepemilikan)
  ktpUrl           String?     // URL foto KTP pemilik motor
  stnkUrl          String?     // URL foto STNK motor
  bpkbUrl          String?     // URL foto BPKB motor (opsional)
  tanggalMasuk     DateTime
  tanggalJatuhTempo DateTime
  statusBayar      StatusBayar @default(BELUM_BAYAR)
  statusTransaksi  StatusTransaksi @default(AKTIF)
  hub              String?   // "suhat" | "tidar" — hub penyimpanan untuk order ini
  zonaRak          String?
  catatanAdmin     String?
  alasanPembatalan String?   // diisi admin saat membatalkan transaksi
  // Nomor urut sekuensial — basis satu-satunya kode transaksi TK-XXXX
  // (lihat src/lib/kode.ts). @unique supaya kode transaksi terjamin unik.
  nomorUrut        Int       @unique @default(autoincrement())
  // "armada" (dijemput TitipKuy!) | "mandiri" (kirim sendiri/Grab/ekspedisi)
  metodePengiriman String?
  // Dicentang admin setelah barang kiriman mandiri benar-benar tiba di hub
  barangTibaMandiri Boolean  @default(false)
  // Layanan antar-jemput (add-on opsional, bukan paket terpisah). Jemput
  // dan Antar dipilih independen — pelanggan bisa pilih salah satu atau
  // keduanya (harga bundling di AntarJemputOption.hargaJemputDanAntar).
  // Armada yang sama dipakai untuk kedua arah, lihat armadaId di bawah.
  layananJemput     Boolean  @default(false)
  layananAntar      Boolean  @default(false)
  antarJemputOption AntarJemputOption? @relation(fields:[antarJemputId], references:[id])
  antarJemputId     String?
  // Booking armada penjemputan (diisi saat incrementSlotUsage dipanggil di
  // alur pemesanan customer maupun order manual admin) — dipakai untuk
  // Rekap Jadwal Perjalanan di panel admin.
  armada             Armada?   @relation(fields:[armadaId], references:[id])
  armadaId           String?
  tanggalPenjemputan DateTime? @db.Date
  sesiPenjemputan    String?   // "pagi" | "siang"
  // Titik lokasi pelanggan (dari GPS device pelanggan di /pesan, atau pin
  // yang ditandai admin di peta saat order manual) — dipakai tim jemput/
  // antar armada lewat link Google Maps di Rekap Jadwal Perjalanan.
  lokasiLat          Float?
  lokasiLng          Float?
  // Order manual via WhatsApp (dibuat admin) — link konfirmasi berbasis token
  konfirmasiToken          String?   @unique
  konfirmasiTokenExpiresAt DateTime?
  // Perjanjian
  perjanjianDisetujui      Boolean   @default(false)
  waktuPersetujuan         DateTime?
  ipAddress                String?
  userAgent                String?
  pdfUrl                   String?   // URL PDF perjanjian di Supabase Storage
  // Centang per klausul (untuk pembuktian hukum)
  klausulLimitGantiRugi    Boolean   @default(false)
  klausulBarangTerlarang   Boolean   @default(false)
  klausulJatuhTempo        Boolean   @default(false)
  klausulDeklarasiNilai    Boolean   @default(false) // hanya jika perluDeklarasi
  klausulPembayaranTidakDirefund Boolean @default(false)
  tandaTanganUrl           String?   // URL gambar TTD di Supabase Storage
  // Dokumentasi foto
  fotoMasuk     FotoBarang[]  @relation("FotoMasuk")
  fotoKeluar    FotoBarang[]  @relation("FotoKeluar")
  barangLabel   BarangLabel[]
  otpPengambilan OtpPengambilan[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// Kode voucher diskon persen yang bisa dipakai pelanggan/admin saat membuat
// transaksi untuk memotong hargaPaketTertagih (lihat src/lib/voucher.ts).
model Voucher {
  id            String    @id @default(cuid())
  kode          String    @unique // e.g. "HEMAT10"
  persenDiskon  Int       // 1-100
  aktif         Boolean   @default(true)
  berlakuMulai  DateTime?
  berlakuSampai DateTime?
  kuota         Int?      // null = tidak terbatas
  terpakai      Int       @default(0)
  deskripsi     String?
  createdAt     DateTime  @default(now())
  transaksi     Transaksi[]
}

// OTP 6 digit dikirim ke WA pelanggan terdaftar untuk verifikasi identitas
// saat pengambilan barang di hub — mencegah orang lain mengambil barang
// dengan hanya mengetahui kode label/QR (yang tertempel di kardus, jadi
// tidak benar-benar rahasia).
model OtpPengambilan {
  id           String   @id @default(cuid())
  transaksiId  String
  kode         String   // 6 digit
  berlakuHingga DateTime
  sudahDipakai Boolean  @default(false)
  createdAt    DateTime @default(now())
  transaksi    Transaksi @relation(fields: [transaksiId], references: [id])
}

model FotoBarang {
  id              String    @id @default(cuid())
  transaksiMasuk  Transaksi? @relation("FotoMasuk", fields:[transaksiMasukId], references:[id])
  transaksiMasukId String?
  transaksiKeluar Transaksi? @relation("FotoKeluar", fields:[transaksiKeluarId], references:[id])
  transaksiKeluarId String?
  url             String    // URL foto di Supabase Storage
  fileName        String
  uploadedAt      DateTime  @default(now())
}

model BarangLabel {
  id          String    @id @default(cuid())
  transaksi   Transaksi @relation(fields:[transaksiId], references:[id])
  transaksiId String
  kodeLabel   String    @unique // TK-[HUB]-[PAKET]-[BARANG]-[XXXX]
  deskripsi   String    // "Kardus 1 - Pakaian", "Laptop Asus", dll
  kategori    String    // "kardus" | "elektronik" | "motor" | "lainnya"
  createdAt   DateTime  @default(now())
}

enum StatusBayar {
  BELUM_BAYAR
  LUNAS
}

enum StatusTransaksi {
  AKTIF
  SELESAI
  DIBATALKAN
}

model Armada {
  id           String   @id @default(cuid())
  nama         String   // "Motor Honda Beat", "Mobil Chevrolet Spin"
  tipe         String   // "motor" | "mobil"
  platNomor    String?
  slotPerHari  Int      @default(4)   // maksimal booking per hari
  aktif        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  slots        SlotArmada[]
  transaksiPenjemputan Transaksi[]
}

model SlotArmada {
  id          String   @id @default(cuid())
  armada      Armada   @relation(fields:[armadaId], references:[id])
  armadaId    String
  tanggal     DateTime @db.Date   // tanggal slot
  sesiWaktu   String   // "pagi" (08-11) | "siang" (13-16)
  hub         String   // "suhat" | "tidar"
  terpakai    Int      @default(0) // jumlah booking yang sudah masuk
  createdAt   DateTime @default(now())
  @@unique([armadaId, tanggal, sesiWaktu, hub])
}

model KonfigurasiOperasional {
  id                    String  @id @default(cuid())
  lockH1                Boolean @default(true)   // kunci slot kurang dari 24 jam
  lockHariMinggu        Boolean @default(true)   // tidak ada armada hari Minggu
  lockTanggalMerah      String  @default("[]")   // JSON array tanggal merah
  pesanHariLibur        String  @default("Kirim mandiri via Grab/Lalamove tersedia 24 jam.")
  updatedAt             DateTime @updatedAt
}

// Layanan antar-jemput sebagai add-on opsional di form pemesanan (bukan
// paket tersendiri) — dipilih pelanggan setelah memilih paket utama.
model AntarJemputOption {
  id             String   @id @default(cuid())
  label          String   // "Motor - Radius <3km", "Mobil - Radius 3-6km"
  tipe           String   // "motor" | "mobil"
  radiusLabel    String   // "<3km" | "3-6km"
  // Harga per varian layanan — Jemput Saja, Antar Saja, dan Jemput+Antar
  // (bundle, biasanya didiskon dari jumlah keduanya). `harga` lama tetap
  // disimpan sinkron dengan hargaJemputSaja untuk kompatibilitas data lama.
  harga               Int
  hargaJemputSaja     Int      @default(0)
  hargaAntarSaja      Int      @default(0)
  hargaJemputDanAntar Int      @default(0)
  kapasitasLabel String?  // "Maks. 2 Box S atau 1 Koper Kabin"
  // Referensi opsional ke Armada.tipe ("motor" | "mobil") — dipakai untuk
  // mencocokkan opsi ini dengan kapasitas slot Armada saat booking, tanpa
  // menggabungkan kedua sistem (Armada tetap sumber kebenaran kapasitas
  // slot per hari, AntarJemputOption tetap sumber harga & pilihan publik).
  tipeArmada     String?
  aktif          Boolean  @default(true)
  urutan         Int      @default(0)
  transaksi      Transaksi[]
}

// Pencatatan pengeluaran operasional harian (bensin, label, packaging, dll)
// untuk dihitung terhadap omzet di Rekap Keuangan (laba bersih & margin).
model Pengeluaran {
  id          String   @id @default(cuid())
  tanggal     DateTime @db.Date
  kategori    String   // "biaya_tetap" | "biaya_variabel" | "pengembangan"
  subKategori String   // "listrik" | "internet" | "bensin" | "label" | "lakban" | "iklan" | "printer" | "lainnya"
  deskripsi   String
  jumlah      Int      // nominal rupiah
  createdAt   DateTime @default(now())
}

// Item modal awal usaha (mis. printer thermal, rak, dll) — dipakai sebagai
// acuan target di BEP Tracker (Rekap Keuangan).
model ModalAwal {
  id          String   @id @default(cuid())
  nama        String   // "Thermal Printer Xprinter XP-420B"
  jumlah      Int      // nominal rupiah
  tanggal     DateTime // tanggal pembelian
  keterangan  String?
  createdAt   DateTime @default(now())
}

// Singleton konfigurasi alokasi laba bulanan (persenOperasional +
// persenPengembangan + persenTabungan + persenPribadi harus = 100).
model KonfigurasiKeuangan {
  id                    String   @id @default(cuid())
  persenOperasional     Int      @default(40)
  persenPengembangan    Int      @default(20)
  persenTabungan        Int      @default(20)
  persenPribadi         Int      @default(20)
  targetModalKembali    Int      @default(0)
  updatedAt             DateTime @updatedAt
}
